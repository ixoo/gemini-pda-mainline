#!/bin/busybox sh
# shellcheck shell=dash

export PATH=/bin
readonly MARKER="GEMINI_SCREEN_MARKER_20260716_E"
readonly STATUS_FILE=/run/screen-marker-status
readonly FRAMEBUFFER=/dev/fb0
readonly FRAMEBUFFER_NAME=/sys/class/graphics/fb0/name
readonly FRAMEBUFFER_SIZE=/sys/class/graphics/fb0/virtual_size
readonly FRAMEBUFFER_BPP=/sys/class/graphics/fb0/bits_per_pixel
readonly FRAMEBUFFER_STRIDE=/sys/class/graphics/fb0/stride
readonly FRAME_BYTES=9400320
readonly MARKER_FILE=/screen-marker.raw

# /dev/null does not exist until devtmpfs is mounted. This must remain the
# first mount and must not be redirected.
if ! mount -t devtmpfs -o nosuid,mode=0755 devtmpfs /dev; then
	printf '%s\n' "$MARKER devtmpfs=failed"
	while :; do
		sleep 30
	done
fi
mount -t proc -o ro,nosuid,nodev,noexec proc /proc 2>/dev/null || true
mount -t sysfs -o ro,nosuid,nodev,noexec sysfs /sys 2>/dev/null || true

emit() {
	for output in /dev/console /dev/tty0 /dev/ttyS0; do
		if [ -c "$output" ]; then
			printf '%s\n' "$*" >"$output" 2>/dev/null || true
		fi
	done
}

record() {
	printf '%s\n' "$*" >>"$STATUS_FILE"
	emit "$*"
}

hold() {
	while :; do
		sleep 30
	done
}

: >"$STATUS_FILE"
record "$MARKER"
record "kernel=$(uname -r)"
record "stage=initramfs"
record "storage_access=none"
record "framebuffer=waiting"

attempt=0
while [ "$attempt" -lt 5 ]; do
	if [ -c "$FRAMEBUFFER" ] && [ -r "$FRAMEBUFFER_NAME" ]; then
		break
	fi
	attempt=$((attempt + 1))
	sleep 1
done

if [ ! -c "$FRAMEBUFFER" ] || [ ! -r "$FRAMEBUFFER_NAME" ]; then
	record "framebuffer=missing"
	hold
fi

fb_name="$(cat "$FRAMEBUFFER_NAME" 2>/dev/null || true)"
fb_size="$(cat "$FRAMEBUFFER_SIZE" 2>/dev/null || true)"
fb_bpp="$(cat "$FRAMEBUFFER_BPP" 2>/dev/null || true)"
fb_stride="$(cat "$FRAMEBUFFER_STRIDE" 2>/dev/null || true)"
record "framebuffer_name=$fb_name"
record "framebuffer_virtual_size=$fb_size"
record "framebuffer_bits_per_pixel=$fb_bpp"
record "framebuffer_stride=$fb_stride"

if [ "$fb_name" != simple ] || [ "$fb_size" != 1080,2160 ] || \
   [ "$fb_bpp" != 32 ] || [ "$fb_stride" != 4352 ]; then
	record "framebuffer_contract=refused"
	hold
fi

marker_size="$(wc -c <"$MARKER_FILE" 2>/dev/null || true)"
if [ "$marker_size" != "$FRAME_BYTES" ]; then
	record "marker_size=refused:$marker_size"
	hold
fi

# Write one visible frame and then leave scanout memory untouched. The marker
# contains eight opaque horizontal bands and covers only stride * height, not
# the larger LK reservation.
if dd if="$MARKER_FILE" of="$FRAMEBUFFER" bs=4352 count=2160 2>"$STATUS_FILE.dd"; then
	printf '%s\n' "framebuffer_write=passed" >>"$STATUS_FILE"
	printf '%s\n' "framebuffer_bytes=$FRAME_BYTES" >>"$STATUS_FILE"
else
	printf '%s\n' "framebuffer_write=failed" >>"$STATUS_FILE"
fi

hold
