#!/bin/busybox sh
# shellcheck shell=dash

export PATH=/bin
readonly MARKER="GEMINI_FBCON_BOUNDARY_20260717_K"
readonly CR_TICKS=20
readonly NEWLINE_TICKS=12

# /dev/null does not exist until devtmpfs is mounted. This must remain the
# first mount and must not be redirected.
if ! mount -t devtmpfs -o nosuid,mode=0755 devtmpfs /dev; then
	printf '%s\n' "$MARKER devtmpfs=failed; STATIC HOLD"
	while :; do
		sleep 3600
	done
fi
mount -t proc -o ro,nosuid,nodev,noexec proc /proc 2>/dev/null || true
mount -t sysfs -o ro,nosuid,nodev,noexec sysfs /sys 2>/dev/null || true

emit_cr() {
	for output in /dev/tty0 /dev/ttyS0; do
		if [ -c "$output" ]; then
			printf '\r%s' "$1" >"$output" 2>/dev/null || true
		fi
	done
}

emit_line() {
	for output in /dev/tty0 /dev/ttyS0; do
		if [ -c "$output" ]; then
			printf '\r%s\n' "$1" >"$output" 2>/dev/null || true
		fi
	done
}

tick=0
while [ "$tick" -lt "$CR_TICKS" ]; do
	sleep 1
	tick=$((tick + 1))
	if [ "$tick" -lt 10 ]; then
		tick_label="0$tick"
	else
		tick_label=$tick
	fi
	emit_cr "$MARKER PHASE1 CR-NO-NL $tick_label/20"
done

emit_line "$MARKER PHASE2 NEWLINE BEGIN 00/12"
tick=0
while [ "$tick" -lt "$NEWLINE_TICKS" ]; do
	sleep 1
	tick=$((tick + 1))
	if [ "$tick" -lt 10 ]; then
		tick_label="0$tick"
	else
		tick_label=$tick
	fi
	emit_line "$MARKER PHASE2 NEWLINE $tick_label/12"
done

emit_line "$MARKER STATIC HOLD; NO FURTHER CONSOLE WRITES"
while :; do
	sleep 3600
done
