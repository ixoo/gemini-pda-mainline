#!/bin/busybox sh
# shellcheck shell=dash

export PATH=/bin
readonly MARKER="GEMINI_A53_SWEEP_20260718_O"
readonly STATUS_FILE=/run/a53-sweep-status
readonly CPU_ERROR_FILE=/run/a53-sweep-error
readonly WATCHDOG_WAIT_SECONDS=10
readonly WATCHDOG_TIMEOUT_SECONDS=31
readonly WATCHDOG_FAILURE_SECONDS=40
readonly LATEST_REQUEST_SECONDS=23
readonly LATEST_ACCOUNTING_SECONDS=25
readonly CPU_DT_SPECS="1:1:a53 2:2:a53 3:3:a53 4:100:a53 5:101:a53 6:102:a53 7:103:a53 8:200:a72 9:201:a72"
readonly SWEEP_CPUS="1 2 3 4 5 6 7"

# /dev/null does not exist until devtmpfs is mounted. This must be first and
# must not be redirected.
if ! mount -t devtmpfs -o nosuid,mode=0755 devtmpfs /dev; then
	printf '%s\n' "$MARKER devtmpfs=failed; STATIC HOLD"
	while :; do
		sleep 3600
	done
fi
procfs_status=failed
sysfs_status=failed
if mount -t proc -o ro,nosuid,nodev,noexec proc /proc 2>/dev/null; then
	procfs_status=mounted
fi
# Candidate O performs only the seven standard CPU-hotplug writes described
# below. No other sysfs path is written by this initramfs.
if mount -t sysfs -o rw,nosuid,nodev,noexec sysfs /sys 2>/dev/null; then
	sysfs_status=mounted-rw
fi

emit_tty() {
	# One direct tty write is enough. Kernel-console logging below supplies the
	# durable copy; avoiding three duplicate tty writes preserves ramoops space.
	for output in /dev/tty0 /dev/console /dev/ttyS0; do
		if [ -c "$output" ] && printf '%s\n' "$*" >"$output" 2>/dev/null; then
			return
		fi
	done
}

record() {
	printf '%s\n' "$*" >>"$STATUS_FILE"
	if [ -c /dev/kmsg ]; then
		printf '<6>%s\n' "$*" >/dev/kmsg 2>/dev/null || true
	fi
	emit_tty "$*"
}

static_hold() {
	while :; do
		sleep 3600
	done
}

driver_name() {
	driver_link=$1
	if [ ! -L "$driver_link" ]; then
		printf '%s' unbound
		return
	fi
	driver_target="$(/bin/busybox readlink "$driver_link" 2>/dev/null || true)"
	printf '%s' "${driver_target##*/}"
}

read_value() {
	value_path=$1
	if [ -r "$value_path" ]; then
		value="$(cat "$value_path" 2>/dev/null || true)"
		printf '%s' "${value:-unreadable}"
	else
		printf '%s' unavailable
	fi
}

read_dt_string() {
	dt_path=$1
	if [ -r "$dt_path" ]; then
		/bin/busybox tr -d '\000' <"$dt_path" 2>/dev/null || true
	fi
}

read_uptime_seconds() {
	uptime_value="$(cat /proc/uptime 2>/dev/null || true)"
	uptime_value=${uptime_value%% *}
	case "$uptime_value" in
		''|*[!0-9.]*) printf '%s' unavailable ;;
		*) printf '%s' "${uptime_value%%.*}" ;;
	esac
}

expected_node_for_cpu() {
	requested_cpu=$1
	for spec in $CPU_DT_SPECS; do
		spec_cpu=${spec%%:*}
		spec_rest=${spec#*:}
		spec_node=${spec_rest%%:*}
		if [ "$spec_cpu" = "$requested_cpu" ]; then
			printf '%s' "$spec_node"
			return 0
		fi
	done
	return 1
}

expected_compatible_for_cpu() {
	requested_cpu=$1
	for spec in $CPU_DT_SPECS; do
		spec_cpu=${spec%%:*}
		spec_rest=${spec#*:}
		spec_class=${spec_rest#*:}
		if [ "$spec_cpu" = "$requested_cpu" ]; then
			printf 'arm,cortex-%s' "$spec_class"
			return 0
		fi
	done
	return 1
}

record_cpu_inventory() {
	state_phase=$1
	for cpu_attribute in possible present online offline; do
		cpu_value="$(read_value "/sys/devices/system/cpu/$cpu_attribute")"
		record "$MARKER cpu_inventory=$state_phase $cpu_attribute=$cpu_value"
	done
}

validate_live_cpu_dtb_contract() {
	for cpu in 1 2 3 4 5 6 7 8 9; do
		expected_node="$(expected_node_for_cpu "$cpu" || true)"
		expected_compatible="$(expected_compatible_for_cpu "$cpu" || true)"
		live_node="/sys/firmware/devicetree/base/cpus/cpu@$expected_node"
		cpu_dir="/sys/devices/system/cpu/cpu$cpu"
		if [ -z "$expected_node" ] || [ -z "$expected_compatible" ] || [ ! -d "$live_node" ]; then
			record "$MARKER cpu=$cpu live_dtb=missing expected_node=cpu@${expected_node:-unknown}"
			return 1
		fi
		compatible="$(read_dt_string "$live_node/compatible")"
		enable_method="$(read_dt_string "$live_node/enable-method")"
		record "$MARKER cpu=$cpu live_dtb=cpu@$expected_node compatible=${compatible:-unavailable} enable_method=${enable_method:-unavailable}"
		[ "$compatible" = "$expected_compatible" ] || return 1
		[ "$enable_method" = psci ] || return 1
		if [ ! -L "$cpu_dir/of_node" ]; then
			record "$MARKER cpu=$cpu logical_mapping=missing expected=cpu@$expected_node"
			return 1
		fi
		logical_of_node="$(/bin/busybox readlink "$cpu_dir/of_node" 2>/dev/null || true)"
		case "$logical_of_node" in
			*/cpus/"cpu@$expected_node") ;;
			*)
				record "$MARKER cpu=$cpu logical_mapping=invalid actual=${logical_of_node:-unavailable} expected=cpu@$expected_node"
				return 1
				;;
		esac
		record "$MARKER cpu=$cpu logical_mapping=cpu@$expected_node class=${expected_compatible#arm,cortex-}"
	done
	return 0
}

validate_initial_cpu_inventory() {
	possible="$(read_value /sys/devices/system/cpu/possible)"
	present="$(read_value /sys/devices/system/cpu/present)"
	online="$(read_value /sys/devices/system/cpu/online)"
	offline="$(read_value /sys/devices/system/cpu/offline)"
	record_cpu_inventory pre-sweep
	[ "$possible" = 0-9 ] || return 1
	[ "$present" = 0-9 ] || return 1
	[ "$online" = 0 ] || return 1
	[ "$offline" = 1-9 ] || return 1
	return 0
}

validate_cpu_precondition() {
	cpu=$1
	expected_node="$(expected_node_for_cpu "$cpu" || true)"
	cpu_dir="/sys/devices/system/cpu/cpu$cpu"
	online_path="$cpu_dir/online"
	if [ ! -d "$cpu_dir" ]; then
		record "$MARKER cpu=$cpu precondition=device-absent"
		return 1
	fi
	if [ ! -L "$cpu_dir/of_node" ]; then
		record "$MARKER cpu=$cpu precondition=of-node-link-absent"
		return 1
	fi
	of_node="$(/bin/busybox readlink "$cpu_dir/of_node" 2>/dev/null || true)"
	record "$MARKER cpu=$cpu of_node=${of_node:-unavailable} expected=cpu@$expected_node"
	case "$of_node" in
		*/cpus/"cpu@$expected_node") ;;
		*)
			record "$MARKER cpu=$cpu precondition=unexpected-of-node"
			return 1
			;;
	esac
	if [ ! -w "$online_path" ]; then
		record "$MARKER cpu=$cpu precondition=online-control-not-writable value=$(read_value "$online_path")"
		return 1
	fi
	initial="$(read_value "$online_path")"
	if [ "$initial" != 0 ]; then
		record "$MARKER cpu=$cpu precondition=expected-offline actual=$initial"
		return 1
	fi
	return 0
}

record_target_cpu_log() {
	cpu=$1
	boot_line="$(dmesg | grep -E "CPU${cpu}: Booted secondary processor" | /bin/busybox tail -n 1 || true)"
	gic_line="$(dmesg | grep -E "GICv3: CPU${cpu}:" | /bin/busybox tail -n 1 || true)"
	icache_line="$(dmesg | grep -E "I-cache on CPU${cpu}" | /bin/busybox tail -n 1 || true)"
	record "$MARKER cpu=$cpu boot_line=${boot_line:-absent}"
	record "$MARKER cpu=$cpu gic_line=${gic_line:-absent}"
	record "$MARKER cpu=$cpu icache_line=${icache_line:-absent}"
	[ -n "$boot_line" ]
}

record_cpu_stat_samples() {
	cpu=$1
	current_uptime="$(read_uptime_seconds)"
	if [ "$current_uptime" = unavailable ]; then
		record "$MARKER cpu=$cpu accounting=uptime-unavailable"
		return 1
	fi
	elapsed=$((current_uptime - armed_reference_seconds))
	if [ "$elapsed" -gt "$LATEST_ACCOUNTING_SECONDS" ]; then
		record "$MARKER cpu=$cpu accounting=budget-insufficient elapsed=${elapsed}s latest_start=${LATEST_ACCOUNTING_SECONDS}s"
		return 1
	fi
	stat_first="$(grep "^cpu${cpu} " /proc/stat 2>/dev/null || true)"
	record "$MARKER cpu=$cpu stat_sample=1 value=${stat_first:-absent} elapsed=${elapsed}s"
	sleep 2
	stat_second="$(grep "^cpu${cpu} " /proc/stat 2>/dev/null || true)"
	record "$MARKER cpu=$cpu stat_sample=2 value=${stat_second:-absent}"
	if [ -n "$stat_first" ] && [ "$stat_first" != "$stat_second" ]; then
		record "$MARKER cpu=$cpu accounting=advanced"
		return 0
	fi
	record "$MARKER cpu=$cpu accounting=not-established"
	return 1
}

wait_for_watchdog_reset() {
	wait_reason=$1
	last_completed_cpu=$2
	elapsed=0
	while [ "$elapsed" -lt "$WATCHDOG_FAILURE_SECONDS" ]; do
		sleep 1
		elapsed=$((elapsed + 1))
		case "$elapsed" in
			5|10|15|20|25|30|35|40)
			record "$MARKER post_action_wait=${elapsed}s reason=$wait_reason last_completed_cpu=$last_completed_cpu global_online=$(read_value /sys/devices/system/cpu/online)"
			;;
		esac
	done
	record "$MARKER watchdog_expiry_failed last_completed_cpu=$last_completed_cpu; STATIC HOLD"
	static_hold
}

request_cpu_online() {
	cpu=$1
	online_path="/sys/devices/system/cpu/cpu$cpu/online"
	current_uptime="$(read_uptime_seconds)"
	if [ "$current_uptime" = unavailable ]; then
		record "$MARKER cpu=$cpu request=uptime-unavailable"
		return 1
	fi
	elapsed=$((current_uptime - armed_reference_seconds))
	if [ "$elapsed" -gt "$LATEST_REQUEST_SECONDS" ]; then
		record "$MARKER cpu=$cpu request=budget-insufficient elapsed=${elapsed}s latest_start=${LATEST_REQUEST_SECONDS}s"
		return 1
	fi
	expected_before=$((cpu - 1))
	if [ "$expected_before" -eq 0 ]; then
		expected_before_mask=0
	else
		expected_before_mask="0-$expected_before"
	fi
	before_mask="$(read_value /sys/devices/system/cpu/online)"
	if [ "$before_mask" != "$expected_before_mask" ]; then
		record "$MARKER cpu=$cpu precondition=unexpected-global-mask expected=$expected_before_mask actual=$before_mask"
		return 1
	fi
	: >"$CPU_ERROR_FILE"
	record "$MARKER cpu=$cpu request=begin requested_state=online elapsed=${elapsed}s"
	if printf '1\n' >"$online_path" 2>"$CPU_ERROR_FILE"; then
		request_status=success
	else
		request_exit=$?
		request_status="failed-exit-$request_exit"
	fi
	final="$(read_value "$online_path")"
	after_mask="$(read_value /sys/devices/system/cpu/online)"
	record "$MARKER cpu=$cpu request=returned status=$request_status final=$final global_online=$after_mask"
	if [ -s "$CPU_ERROR_FILE" ]; then
		/bin/busybox tail -n 4 "$CPU_ERROR_FILE" | while IFS= read -r error_line; do
			record "$MARKER cpu=$cpu write_error=$error_line"
		done
	else
		record "$MARKER cpu=$cpu write_error=none"
	fi
	expected_after_mask="0-$cpu"
	if [ "$request_status" != success ] || [ "$final" != 1 ] || [ "$after_mask" != "$expected_after_mask" ]; then
		record "$MARKER cpu=$cpu result=not-online request_status=$request_status final=$final expected_mask=$expected_after_mask actual_mask=$after_mask"
		return 1
	fi
	if ! record_target_cpu_log "$cpu"; then
		record "$MARKER cpu=$cpu result=boot-line-absent"
		return 1
	fi
	if ! record_cpu_stat_samples "$cpu"; then
		record "$MARKER cpu=$cpu result=execution-not-established"
		return 1
	fi
	stable_mask="$(read_value /sys/devices/system/cpu/online)"
	stable_state="$(read_value "$online_path")"
	if [ "$stable_mask" != "$expected_after_mask" ] || [ "$stable_state" != 1 ]; then
		record "$MARKER cpu=$cpu result=post-sample-state-changed expected_mask=$expected_after_mask actual_mask=$stable_mask state=$stable_state"
		return 1
	fi
	record "$MARKER cpu=$cpu checkpoint=PASS global_online=$stable_mask accounting=advanced"
	return 0
}

run_a53_sweep() {
	# This function owns fd 3 through the invocation redirection below. Opening
	# a regular function—not redirecting ash's exec special builtin—keeps an
	# open failure in the caller's conditional path.
	if ! printf '.' >&3; then
		record "$MARKER watchdog0=handoff-ping-failed recovery=reset-possible"
		wait_for_watchdog_reset watchdog-ping-failed 0
	fi
	armed_reference_seconds="$(read_uptime_seconds)"
	if [ "$armed_reference_seconds" = unavailable ]; then
		record "$MARKER watchdog0=armed uptime_reference=unavailable"
		wait_for_watchdog_reset uptime-unavailable 0
	fi
	record "$MARKER watchdog0=armed handoff_ping=sent timeout_seconds=$WATCHDOG_TIMEOUT_SECONDS armed_reference_uptime=${armed_reference_seconds}s cpu_sweep_after_arm=yes"

	if ! validate_initial_cpu_inventory; then
		record "$MARKER sweep_precondition=unexpected-inventory"
		wait_for_watchdog_reset precondition-inventory 0
	fi
	if ! validate_live_cpu_dtb_contract; then
		record "$MARKER sweep_precondition=live-dtb-invalid"
		wait_for_watchdog_reset precondition-live-dtb 0
	fi

	last_completed_cpu=0
	for cpu in $SWEEP_CPUS; do
		if ! validate_cpu_precondition "$cpu"; then
			record "$MARKER sweep=STOP cpu=$cpu reason=precondition last_completed_cpu=$last_completed_cpu"
			wait_for_watchdog_reset cpu-precondition-failed "$last_completed_cpu"
		fi
		if ! request_cpu_online "$cpu"; then
			record "$MARKER sweep=STOP cpu=$cpu reason=request-or-execution last_completed_cpu=$last_completed_cpu"
			wait_for_watchdog_reset cpu-request-failed "$last_completed_cpu"
		fi
		last_completed_cpu=$cpu
	done

	final_online="$(read_value /sys/devices/system/cpu/online)"
	final_offline="$(read_value /sys/devices/system/cpu/offline)"
	cpu8_state="$(read_value /sys/devices/system/cpu/cpu8/online)"
	cpu9_state="$(read_value /sys/devices/system/cpu/cpu9/online)"
	if [ "$final_online" != 0-7 ] || [ "$final_offline" != 8-9 ] || \
		[ "$cpu8_state" != 0 ] || [ "$cpu9_state" != 0 ]; then
		record "$MARKER sweep=STOP reason=final-mask online=$final_online offline=$final_offline cpu8=$cpu8_state cpu9=$cpu9_state last_completed_cpu=$last_completed_cpu"
		wait_for_watchdog_reset final-mask-failed "$last_completed_cpu"
	fi
	record "$MARKER sweep_result=online-0-7 SUCCESS cpu8=offline cpu9=offline"
	wait_for_watchdog_reset sweep-success 7
}

: >"$STATUS_FILE"
emit_tty "$MARKER stage=initramfs-entered"
if [ -c /dev/kmsg ] && \
	printf '<6>%s\n' "$MARKER kmsg_probe=write" >/dev/kmsg 2>/dev/null; then
	emit_tty "$MARKER kmsg_write=success"
else
	emit_tty "$MARKER kmsg_write=failed"
fi
record "$MARKER kernel=$(uname -r)"
record "$MARKER storage_access=none runtime_networking=none"
record "$MARKER kernel_dtb_config=exact-candidate-N cpu_test=cpu1-7-sequential cpu8-9=reserved-offline"
record "$MARKER procfs=$procfs_status sysfs=$sysfs_status"
if [ "$procfs_status" != mounted ] || [ "$sysfs_status" != mounted-rw ]; then
	record "$MARKER filesystems=failed diagnostic=invalid; STATIC HOLD"
	static_hold
fi

live_watchdog_node=/sys/firmware/devicetree/base/watchdog@10007000
if [ ! -d "$live_watchdog_node" ] || [ -e "$live_watchdog_node/interrupts" ]; then
	record "$MARKER live_watchdog_contract=invalid; STATIC HOLD"
	static_hold
fi
record "$MARKER live_watchdog_interrupts=absent"

watchdog_platform=/sys/bus/platform/devices/10007000.watchdog
remaining=$WATCHDOG_WAIT_SECONDS
while [ "$remaining" -gt 0 ] && [ ! -c /dev/watchdog0 ]; do
	record "$MARKER watchdog_wait_for_device=${remaining}s platform=$([ -d "$watchdog_platform" ] && printf present || printf absent) driver=$(driver_name "$watchdog_platform/driver")"
	sleep 1
	remaining=$((remaining - 1))
done
if [ ! -c /dev/watchdog0 ]; then
	record "$MARKER watchdog0=missing; STATIC HOLD"
	static_hold
fi
watchdog_identity="$(read_value /sys/class/watchdog/watchdog0/identity)"
watchdog_timeout="$(read_value /sys/class/watchdog/watchdog0/timeout)"
watchdog_pretimeout="$(read_value /sys/class/watchdog/watchdog0/pretimeout)"
watchdog_status="$(read_value /sys/class/watchdog/watchdog0/status)"
watchdog_driver="$(driver_name "$watchdog_platform/driver")"
watchdog_device="$(/bin/busybox readlink /sys/class/watchdog/watchdog0/device 2>/dev/null || true)"
record "$MARKER watchdog_identity=$watchdog_identity timeout=$watchdog_timeout pretimeout=$watchdog_pretimeout status=$watchdog_status driver=$watchdog_driver device=${watchdog_device:-unavailable}"
case "$watchdog_device" in
	*10007000.watchdog) watchdog_device_valid=yes ;;
	*) watchdog_device_valid=no ;;
esac
if [ "$watchdog_identity" != mtk-wdt ] || [ "$watchdog_timeout" != "$WATCHDOG_TIMEOUT_SECONDS" ] || \
	[ "$watchdog_driver" != mtk-wdt ] || [ "$watchdog_device_valid" != yes ]; then
	record "$MARKER watchdog0=unexpected-device; STATIC HOLD"
	static_hold
fi

record "$MARKER watchdog0=opening"
if run_a53_sweep 3>/dev/watchdog0; then
	record "$MARKER sweep=unexpected-return; STATIC HOLD"
	static_hold
else
	record "$MARKER watchdog0=open-failed; STATIC HOLD"
	static_hold
fi
