#!/bin/busybox sh
# shellcheck shell=dash

export PATH=/bin
readonly MARKER="GEMINI_FBCON_TEXT_20260716_G"
readonly FRAMEBUFFER_NAME=/sys/class/graphics/fb0/name
readonly FRAMEBUFFER_SIZE=/sys/class/graphics/fb0/virtual_size
readonly FRAMEBUFFER_BPP=/sys/class/graphics/fb0/bits_per_pixel
readonly FRAMEBUFFER_STRIDE=/sys/class/graphics/fb0/stride

# /dev/null does not exist until devtmpfs is mounted. This must remain the
# first mount and must not be redirected.
if ! mount -t devtmpfs -o nosuid,mode=0755 devtmpfs /dev; then
	printf '%s\n' "$MARKER devtmpfs=failed"
	while :; do
		sleep 30
	done
fi
mount -t proc -o ro,nosuid,nodev,noexec proc /proc 2>/dev/null || true
mount -t sysfs -o ro,nosuid,nodev,noexec sysfs /sys 2>/dev/null || true

emit() {
	for output in /dev/tty0 /dev/ttyS0; do
		if [ -c "$output" ]; then
			printf '%s\n' "$*" >"$output" 2>/dev/null || true
		fi
	done
}

emit ""
emit "=== $MARKER ==="
emit "LINUX INITRAMFS REACHED: $(uname -r)"
emit "RAW FRAMEBUFFER WRITE: NONE"
emit "STORAGE ACCESS: NONE"
emit "FBCON ROTATION: NOT COMPILED; SIDEWAYS IS EXPECTED"

attempt=0
while [ "$attempt" -lt 5 ]; do
	if [ -r "$FRAMEBUFFER_NAME" ]; then
		break
	fi
	attempt=$((attempt + 1))
	sleep 1
done

if [ -r "$FRAMEBUFFER_NAME" ]; then
	fb_name="$(cat "$FRAMEBUFFER_NAME" 2>/dev/null || true)"
	fb_size="$(cat "$FRAMEBUFFER_SIZE" 2>/dev/null || true)"
	fb_bpp="$(cat "$FRAMEBUFFER_BPP" 2>/dev/null || true)"
	fb_stride="$(cat "$FRAMEBUFFER_STRIDE" 2>/dev/null || true)"
	emit "FBCON SOURCE: $fb_name $fb_size ${fb_bpp}BPP STRIDE=$fb_stride"
else
	emit "FBCON SOURCE: SYSFS METADATA MISSING"
fi
emit "STATE: HOLDING; HEARTBEAT UPDATES EVERY 30 SECONDS"

heartbeat=0
while :; do
	sleep 30
	heartbeat=$((heartbeat + 1))
	for output in /dev/tty0 /dev/ttyS0; do
		if [ -c "$output" ]; then
			printf '\rCANDIDATE G HOLDING: HEARTBEAT=%s   ' "$heartbeat" \
				>"$output" 2>/dev/null || true
		fi
	done
done
