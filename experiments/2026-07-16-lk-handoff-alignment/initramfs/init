#!/bin/busybox sh
# shellcheck shell=dash

export PATH=/bin
readonly MARKER="GEMINI_LK_HANDOFF_20260716_A"

mount -t devtmpfs -o nosuid,mode=0755 devtmpfs /dev 2>/dev/null || true
mount -t proc -o nosuid,nodev,noexec proc /proc 2>/dev/null || true
mount -t sysfs -o nosuid,nodev,noexec sysfs /sys 2>/dev/null || true

emit() {
	for output in /dev/console /dev/tty0 /dev/ttyS0; do
		if [ -c "$output" ]; then
			printf '%s\n' "$*" >"$output" 2>/dev/null || true
		fi
	done
}

emit "$MARKER"
emit "kernel=$(uname -r)"
emit "stage=initramfs"
emit "storage_access=none"
if [ -d /sys/class/graphics/fb0 ]; then
	emit "framebuffer=present"
else
	emit "framebuffer=absent"
fi
if [ -r /sys/devices/system/cpu/online ]; then
	emit "cpu_online=$(cat /sys/devices/system/cpu/online)"
fi
if [ -r /proc/cmdline ]; then
	for token in $(cat /proc/cmdline); do
		case "$token" in
			console=*|earlycon*|maxcpus=*|nokaslr|ignore_loglevel|loglevel=*|rdinit=*|panic=*)
				emit "cmdline_$token"
				;;
		esac
	done
fi

# Repeat a unique, non-sensitive marker so a late-attaching console still has
# an observable signal. PID 1 deliberately performs no storage or device I/O.
while :; do
	sleep 30
	emit "$MARKER heartbeat"
done
