#!/bin/busybox sh
# shellcheck shell=dash

export PATH=/bin
readonly MARKER="GEMINI_FBCON_REFRESH_20260716_I"
readonly LAST_TICK=60

# /dev/null does not exist until devtmpfs is mounted. This must remain the
# first mount and must not be redirected.
if ! mount -t devtmpfs -o nosuid,mode=0755 devtmpfs /dev; then
	printf '%s\n' "$MARKER devtmpfs=failed; STATIC HOLD"
	while :; do
		sleep 3600
	done
fi
mount -t proc -o ro,nosuid,nodev,noexec proc /proc 2>/dev/null || true
mount -t sysfs -o ro,nosuid,nodev,noexec sysfs /sys 2>/dev/null || true

emit() {
	for output in /dev/tty0 /dev/ttyS0; do
		if [ -c "$output" ]; then
			printf '%s\n' "$*" >"$output" 2>/dev/null || true
		fi
	done
}

tick=0
while [ "$tick" -lt "$LAST_TICK" ]; do
	sleep 1
	tick=$((tick + 1))
	if [ "$tick" -lt 10 ]; then
		tick_label="0$tick"
	else
		tick_label=$tick
	fi
	emit "$MARKER T+$tick_label ACTIVE REFRESH $tick_label/60"
done

emit "$MARKER T+60 STATIC HOLD; NO FURTHER CONSOLE WRITES"
while :; do
	sleep 3600
done
