+++ b/arch/arm64/boot/dts/mediatek/mt6797.dtsi
@@ -528,12 +528,25 @@ i2c3: i2c@11014000 {
 		status = "disabled";
 	};
 
+	auxadc: adc@11001000 {
+		compatible = "mediatek,mt6797-auxadc";
+		reg = <0 0x11001000 0 0x1000>;
+		clocks = <&infrasys CLK_INFRA_AUXADC>;
