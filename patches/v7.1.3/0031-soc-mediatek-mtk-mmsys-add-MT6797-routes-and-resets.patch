+		    MT6797_DISP_UFOE_MOUT_EN, 0x1, 0x1),
+	MMSYS_ROUTE(UFOE, DSI0,
+		    MT6797_DSI0_SEL_IN, 0x3, 0x0),
+	MMSYS_ROUTE(UFOE, DSI1,
