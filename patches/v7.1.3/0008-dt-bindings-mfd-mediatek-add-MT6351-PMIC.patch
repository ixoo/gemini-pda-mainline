From afeee4bb0a2a3370cfd33ff9fdc88242fbf4f588 Mon Sep 17 00:00:00 2001
From: Julien Etienne <julien.etienne@gmail.com>
Date: Sun, 12 Jul 2026 00:00:25 -0400
Subject: [PATCH] dt-bindings: mfd: mediatek: add MT6351 PMIC

MT6351 is the companion PMIC used with MT6797. It exposes regulator,
RTC, audio codec, and key functions behind the PMIC wrapper, with
distinct press and release interrupts for its keys.

Add the core compatible and the child compatibles consumed by the MFD
cells and existing subsystem bindings.

Signed-off-by: Julien Etienne <julien.etienne@gmail.com>
---
 .../devicetree/bindings/input/mediatek,pmic-keys.yaml  |  1 +
 .../devicetree/bindings/mfd/mediatek,mt6397.yaml       | 10 +++++++---
 2 files changed, 8 insertions(+), 3 deletions(-)

diff --git a/Documentation/devicetree/bindings/input/mediatek,pmic-keys.yaml b/Documentation/devicetree/bindings/input/mediatek,pmic-keys.yaml
index b95435bd6..a00d34aa0 100644
--- a/Documentation/devicetree/bindings/input/mediatek,pmic-keys.yaml
+++ b/Documentation/devicetree/bindings/input/mediatek,pmic-keys.yaml
@@ -27,6 +27,7 @@ properties:
       - mediatek,mt6323-keys
       - mediatek,mt6328-keys
       - mediatek,mt6331-keys
+      - mediatek,mt6351-keys
       - mediatek,mt6357-keys
       - mediatek,mt6358-keys
       - mediatek,mt6359-keys
diff --git a/Documentation/devicetree/bindings/mfd/mediatek,mt6397.yaml b/Documentation/devicetree/bindings/mfd/mediatek,mt6397.yaml
index 05c121b0c..d635ac718 100644
--- a/Documentation/devicetree/bindings/mfd/mediatek,mt6397.yaml
+++ b/Documentation/devicetree/bindings/mfd/mediatek,mt6397.yaml
@@ -4,17 +4,17 @@
 $id: http://devicetree.org/schemas/mfd/mediatek,mt6397.yaml#
 $schema: http://devicetree.org/meta-schemas/core.yaml#
 
-title: MediaTek MT6397/MT6323 PMIC
+title: MediaTek MT6397/MT6323/MT6351 PMIC
 
 maintainers:
   - Sen Chu <sen.chu@mediatek.com>
   - Macpaul Lin <macpaul.lin@mediatek.com>
 
 description: |
-  MT6397/MT6323 is a power management system chip.
+  MT6397/MT6323/MT6351 is a power management system chip.
   Please see the sub-modules below for supported features.
 
-  MT6397/MT6323 is a multifunction device with the following sub modules:
+  MT6397/MT6323/MT6351 is a multifunction device with the following sub modules:
   - Regulators
   - RTC
   - ADC
@@ -37,6 +37,7 @@ properties:
           - mediatek,mt6323
           - mediatek,mt6331 # "mediatek,mt6331" for PMIC MT6331 and MT6332.
           - mediatek,mt6328
+          - mediatek,mt6351
           - mediatek,mt6358
           - mediatek,mt6359
           - mediatek,mt6397
@@ -66,6 +67,7 @@ properties:
           - enum:
               - mediatek,mt6323-rtc
               - mediatek,mt6331-rtc
+              - mediatek,mt6351-rtc
               - mediatek,mt6358-rtc
               - mediatek,mt6397-rtc
           - items:
@@ -91,6 +93,7 @@ properties:
               - mediatek,mt6323-regulator
               - mediatek,mt6328-regulator
               - mediatek,mt6331-regulator
+              - mediatek,mt6351-regulator
               - mediatek,mt6358-regulator
               - mediatek,mt6359-regulator
               - mediatek,mt6397-regulator
@@ -117,6 +120,7 @@ properties:
       compatible:
         oneOf:
           - enum:
+              - mediatek,mt6351-sound
               - mediatek,mt6358-sound
               - mediatek,mt6359-codec
               - mediatek,mt6397-codec
-- 
2.43.0
