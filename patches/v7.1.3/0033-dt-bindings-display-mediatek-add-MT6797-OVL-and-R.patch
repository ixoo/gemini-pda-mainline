From 9a8f04a1ac183b202c7534f0252407318ba8c3a6 Mon Sep 17 00:00:00 2001
From: Gemini PDA Mainline Project <noreply@example.com>
Date: Sun, 12 Jul 2026 08:33:34 -0400
Subject: [PATCH 33/34] dt-bindings: display: mediatek: add MT6797 OVL and RDMA

MT6797 has one four-layer OVL, two two-layer OVL blocks, and two RDMA
blocks in its multimedia subsystem. Add dedicated compatibles so they can
be described without claiming fallback compatibility for unevidenced
platform data.

Signed-off-by: Gemini PDA Mainline Project <noreply@example.com>
---
 .../devicetree/bindings/display/mediatek/mediatek,ovl-2l.yaml    | 1 +
 .../devicetree/bindings/display/mediatek/mediatek,ovl.yaml       | 1 +
 .../devicetree/bindings/display/mediatek/mediatek,rdma.yaml      | 1 +
 3 files changed, 3 insertions(+)

diff --git a/Documentation/devicetree/bindings/display/mediatek/mediatek,ovl-2l.yaml b/Documentation/devicetree/bindings/display/mediatek/mediatek,ovl-2l.yaml
index bacdfe7d0..5c48f804d 100644
--- a/Documentation/devicetree/bindings/display/mediatek/mediatek,ovl-2l.yaml
+++ b/Documentation/devicetree/bindings/display/mediatek/mediatek,ovl-2l.yaml
@@ -22,6 +22,7 @@ properties:
   compatible:
     oneOf:
       - enum:
+          - mediatek,mt6797-disp-ovl-2l
           - mediatek,mt8183-disp-ovl-2l
           - mediatek,mt8192-disp-ovl-2l
       - items:
diff --git a/Documentation/devicetree/bindings/display/mediatek/mediatek,ovl.yaml b/Documentation/devicetree/bindings/display/mediatek/mediatek,ovl.yaml
index 679f731f0..742ecf99e 100644
--- a/Documentation/devicetree/bindings/display/mediatek/mediatek,ovl.yaml
+++ b/Documentation/devicetree/bindings/display/mediatek/mediatek,ovl.yaml
@@ -25,6 +25,7 @@ properties:
           - mediatek,mt2701-disp-ovl
           - mediatek,mt8167-disp-ovl
           - mediatek,mt8173-disp-ovl
+          - mediatek,mt6797-disp-ovl
           - mediatek,mt8183-disp-ovl
           - mediatek,mt8192-disp-ovl
           - mediatek,mt8195-disp-ovl
diff --git a/Documentation/devicetree/bindings/display/mediatek/mediatek,rdma.yaml b/Documentation/devicetree/bindings/display/mediatek/mediatek,rdma.yaml
index cb187a95c..9986dafa3 100644
--- a/Documentation/devicetree/bindings/display/mediatek/mediatek,rdma.yaml
+++ b/Documentation/devicetree/bindings/display/mediatek/mediatek,rdma.yaml
@@ -26,6 +26,7 @@ properties:
       - enum:
           - mediatek,mt2701-disp-rdma
           - mediatek,mt8173-disp-rdma
+          - mediatek,mt6797-disp-rdma
           - mediatek,mt8183-disp-rdma
           - mediatek,mt8195-disp-rdma
       - items:
