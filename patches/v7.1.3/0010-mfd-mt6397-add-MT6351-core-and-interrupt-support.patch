 drivers/mfd/mt6397-irq.c             | 66 +++++++++++++------------
 include/linux/mfd/mt6351/core.h      | 73 ++++++++++++++++++++++++++++
 include/linux/mfd/mt6351/registers.h | 27 ++++++++++
 include/linux/mfd/mt6397/core.h      | 12 +++--
 5 files changed, 191 insertions(+), 35 deletions(-)
 create mode 100644 include/linux/mfd/mt6351/core.h
 create mode 100644 include/linux/mfd/mt6351/registers.h

