+
 #define MT6358_RTC_BASE		0x0588
 #define MT6358_RTC_SIZE		0x3c
 
@@ -60,6 +65,11 @@ static const struct resource mt6331_rtc_resources[] = {
 	DEFINE_RES_IRQ(MT6331_IRQ_STATUS_RTC),
 };
 
