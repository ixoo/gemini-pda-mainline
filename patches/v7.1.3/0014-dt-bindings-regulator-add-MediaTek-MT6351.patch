From 8f2c9162078396c2288b2ef16178f9c382e3c6b7 Mon Sep 17 00:00:00 2001
From: Julien Etienne <julien.etienne@gmail.com>
Date: Sun, 12 Jul 2026 00:49:29 -0400
Subject: [PATCH] dt-bindings: regulator: add MediaTek MT6351

MT6351 provides nine buck regulators and 30 independently controlled
LDO outputs. Add a schema for the regulator container and its hardware
rail names.

The rail inventory and naming are cross-checked against the MT6797
vendor implementation and live MT6351 E2 register state.

Signed-off-by: Julien Etienne <julien.etienne@gmail.com>
---
 .../regulator/mediatek,mt6351-regulator.yaml  | 62 +++++++++++++++++++
 1 file changed, 62 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/regulator/mediatek,mt6351-regulator.yaml

diff --git a/Documentation/devicetree/bindings/regulator/mediatek,mt6351-regulator.yaml b/Documentation/devicetree/bindings/regulator/mediatek,mt6351-regulator.yaml
new file mode 100644
index 000000000..1ff159833
--- /dev/null
+++ b/Documentation/devicetree/bindings/regulator/mediatek,mt6351-regulator.yaml
@@ -0,0 +1,62 @@
+# SPDX-License-Identifier: (GPL-2.0 OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/regulator/mediatek,mt6351-regulator.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: MediaTek MT6351 regulators
+
+maintainers:
+  - Julien Etienne <julien.etienne@gmail.com>
+
+description: |
+  The MT6351 PMIC provides nine buck regulators and 30 independently
+  controlled LDO regulator outputs. The regulators node is a child of the
+  MT6351 MFD node. Regulator nodes are named for their hardware rail using
+  buck-<name> and ldo-<name>.
+
+properties:
+  compatible:
+    const: mediatek,mt6351-regulator
+
+patternProperties:
+  "^buck-v(core|gpu|md1|modem|pa|s1|s2|sram-md|sram-proc)$":
+    type: object
+    $ref: regulator.yaml#
+    unevaluatedProperties: false
+
+  "^ldo-v(a10|a18|bif28|cama|camd|camio|cn18|cn28|cn33-bt|cn33-wifi|dram|efuse|emc|gp3|ibr|io18|io28|ldo28|ldo28-1|mc|mch|mipi|rf12|rf18|sim1|sim2|tcxo24|tcxo28|usb33|xo22)$":
+    type: object
+    $ref: regulator.yaml#
+    unevaluatedProperties: false
+
+required:
+  - compatible
+
+additionalProperties: false
+
+examples:
+  - |
+    pmic {
+      regulators {
+        compatible = "mediatek,mt6351-regulator";
+
+        mt6351_vemc_reg: ldo-vemc {
+          regulator-name = "vemc";
+          regulator-min-microvolt = <3000000>;
+          regulator-max-microvolt = <3300000>;
+        };
+
+        mt6351_vmch_reg: ldo-vmch {
+          regulator-name = "vmch";
+          regulator-min-microvolt = <3000000>;
+          regulator-max-microvolt = <3300000>;
+        };
+
+        mt6351_vmc_reg: ldo-vmc {
+          regulator-name = "vmc";
+          regulator-min-microvolt = <1200000>;
+          regulator-max-microvolt = <3300000>;
+        };
+      };
+    };
-- 
