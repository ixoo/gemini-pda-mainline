From e7ce0bd80552a8a257ec76784e84d4618410bbe8 Mon Sep 17 00:00:00 2001
From: Julien Etienne <julien.etienne@gmail.com>
Date: Sat, 11 Jul 2026 22:47:48 -0400
Subject: [PATCH 1/3] dt-bindings: reset: mediatek: add MT6797 infracfg resets

MT6797 has three simple infracfg reset banks at offsets 0x120,
0x124 and 0x128.

Define the recovered reset IDs and require #reset-cells for the
existing infracfg compatible.

Signed-off-by: Julien Etienne <julien.etienne@gmail.com>
---
 .../bindings/clock/mediatek,infracfg.yaml     |  1 +
 include/dt-bindings/reset/mt6797-resets.h     | 37 +++++++++++++++++++
 2 files changed, 38 insertions(+)
 create mode 100644 include/dt-bindings/reset/mt6797-resets.h

diff --git a/Documentation/devicetree/bindings/clock/mediatek,infracfg.yaml b/Documentation/devicetree/bindings/clock/mediatek,infracfg.yaml
index d1d30700d..5b412ef90 100644
--- a/Documentation/devicetree/bindings/clock/mediatek,infracfg.yaml
+++ b/Documentation/devicetree/bindings/clock/mediatek,infracfg.yaml
@@ -66,6 +66,7 @@ if:
           - mediatek,mt2701-infracfg
           - mediatek,mt2712-infracfg
           - mediatek,mt6795-infracfg
+          - mediatek,mt6797-infracfg
           - mediatek,mt7622-infracfg
           - mediatek,mt7986-infracfg
           - mediatek,mt8135-infracfg
diff --git a/include/dt-bindings/reset/mt6797-resets.h b/include/dt-bindings/reset/mt6797-resets.h
new file mode 100644
index 000000000..b02036879
--- /dev/null
+++ b/include/dt-bindings/reset/mt6797-resets.h
@@ -0,0 +1,37 @@
+/* SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause) */
+#ifndef _DT_BINDINGS_RESET_CONTROLLER_MT6797
+#define _DT_BINDINGS_RESET_CONTROLLER_MT6797
+
+/* INFRACFG resets: INFRA_GLOBALCON_RST0 */
+#define MT6797_INFRA_THERM_CTRL_RST		0
+#define MT6797_INFRA_USB_TOP_RST		1
+#define MT6797_INFRA_PERI_IOMMU_RST		2
+#define MT6797_INFRA_MM_IOMMU_RST		3
+#define MT6797_INFRA_MSDC3_RST			4
+#define MT6797_INFRA_MSDC2_RST			5
+#define MT6797_INFRA_MSDC1_RST			6
+#define MT6797_INFRA_MSDC0_RST			7
+#define MT6797_INFRA_DRAMC_RST			8
+#define MT6797_INFRA_AP_DMA_RST			9
+#define MT6797_INFRA_MIPI_D_RST			10
+#define MT6797_INFRA_MIPI_C_RST			11
+#define MT6797_INFRA_BTIF_RST			12
+#define MT6797_INFRA_CLDMA_RST			13
+#define MT6797_INFRA_DVFS_PROC_0_RST		14
+#define MT6797_INFRA_DVFS_PROC_1_RST		15
+#define MT6797_INFRA_L2C_INFRA_0_RST		16
+
+/* INFRACFG resets: INFRA_GLOBALCON_RST1 */
+#define MT6797_INFRA_SSUSB_TOP_RST		33
+#define MT6797_INFRA_L2C_INFRA_1_RST		48
+
+/* INFRACFG resets: INFRA_GLOBALCON_RST2 */
+#define MT6797_INFRA_PMIC_WRAP_RST		64
+#define MT6797_INFRA_SPM_RST			65
+#define MT6797_INFRA_USBSIF_RST			66
+#define MT6797_INFRA_SCP_RST			67
+#define MT6797_INFRA_CLDMA_AO_RST		68
+#define MT6797_INFRA_SCP_SECURE_RST		69
+#define MT6797_INFRA_SSUSB_DIG_PHY_B_RST	70
+
+#endif /* _DT_BINDINGS_RESET_CONTROLLER_MT6797 */
-- 
