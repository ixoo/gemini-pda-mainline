+#define MT6351_BUCK_QI		BIT(13)
+#define MT6351_BUCK_VOSEL_CTRL	BIT(1)
+#define MT6351_LDO_EN		BIT(1)
+
+struct mt6351_regulator_info {
+	struct regulator_desc desc;
+	u16 qi;
+	u16 vsel_on_reg;
