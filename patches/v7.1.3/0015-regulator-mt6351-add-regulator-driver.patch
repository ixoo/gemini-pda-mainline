+	MT6351_LDO("ldo-vtcxo24", VTCXO24, mt6351_ldo_voltages_rev4,
+		   MT6351_LDO_VTCXO24_CON0, MT6351_LDO_VTCXO24_VOSEL, GENMASK(9, 8)),
