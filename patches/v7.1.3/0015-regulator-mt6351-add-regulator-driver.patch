+
+#define MT6351_BUCK(_match, _name, _range, _max_sel, _ctrl, _en, _vsel, _on, _mask) \
+[MT6351_ID_##_name] = { \
+	.desc = { \
+		.name = #_name, \
+		.of_match = of_match_ptr(_match), \
+		.ops = &mt6351_buck_ops, \
+		.type = REGULATOR_VOLTAGE, \
+		.id = MT6351_ID_##_name, \
+		.owner = THIS_MODULE, \
+		.n_voltages = (_max_sel) + 1, \
+		.linear_ranges = _range, \
+		.n_linear_ranges = ARRAY_SIZE(_range), \
+		.vsel_reg = _vsel, \
+		.vsel_mask = _mask, \
+		.enable_reg = _en, \
+		.enable_mask = BIT(0), \
+	}, \
+	.qi = MT6351_BUCK_QI, \
+	.vsel_on_reg = _on, \
+	.vsel_ctrl_reg = _ctrl, \
+}
+
+#define MT6351_LDO(_match, _name, _table, _en, _vsel, _mask) \
+[MT6351_ID_##_name] = { \
+	.desc = { \
+		.name = #_name, \
+		.of_match = of_match_ptr(_match), \
+		.ops = &mt6351_ldo_ops, \
+		.type = REGULATOR_VOLTAGE, \
+		.id = MT6351_ID_##_name, \
+		.owner = THIS_MODULE, \
+		.n_voltages = ARRAY_SIZE(_table), \
+		.volt_table = _table, \
+		.vsel_reg = _vsel, \
+		.vsel_mask = _mask, \
+		.enable_reg = _en, \
+		.enable_mask = MT6351_LDO_EN, \
+	}, \
+}
+
+#define MT6351_FIXED(_match, _name, _en, _voltage) \
+[MT6351_ID_##_name] = { \
+	.desc = { \
+		.name = #_name, \
+		.of_match = of_match_ptr(_match), \
+		.ops = &mt6351_fixed_ops, \
+		.type = REGULATOR_VOLTAGE, \
+		.id = MT6351_ID_##_name, \
+		.owner = THIS_MODULE, \
