+		    MT6351_BUCK_VSRAM_MD_CON4, MT6351_BUCK_VSRAM_MD_CON5, GENMASK(6, 0)),
+	MT6351_BUCK("buck-vs1", VS1, mt6351_buck_range, 0x7f,
