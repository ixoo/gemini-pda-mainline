From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Julien Etienne <julien.etienne@gmail.com>
Date: Mon, 13 Jul 2026 09:16:00 -0400
Subject: [PATCH] dt-bindings: sound: mediatek: add MT6797 AFE binding

The MT6797 AFE driver is present in the kernel, but its device-tree contract
was only documented in the legacy text binding.  Make the exact eight-clock
contract machine-checkable so Gemini's disabled AFE node can be validated.

Signed-off-by: Julien Etienne <julien.etienne@gmail.com>
---
 Documentation/devicetree/bindings/sound/mediatek,mt6797-afe-pcm.yaml | 66 ++++++++++++++++
 1 file changed, 66 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/sound/mediatek,mt6797-afe-pcm.yaml

diff --git a/Documentation/devicetree/bindings/sound/mediatek,mt6797-afe-pcm.yaml b/Documentation/devicetree/bindings/sound/mediatek,mt6797-afe-pcm.yaml
new file mode 100644
--- /dev/null
+++ b/Documentation/devicetree/bindings/sound/mediatek,mt6797-afe-pcm.yaml
@@ -0,0 +1,49 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/sound/mediatek,mt6797-afe-pcm.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: MediaTek MT6797 Audio Front End PCM controller
+
+maintainers:
+  - Tzung-Bi Shih <tzungbi@chromium.org>
+  - Jiaxin Yu <jiaxin.yu@mediatek.com>
+
+properties:
+  compatible:
+    const: mediatek,mt6797-audio
+
+  reg:
+    maxItems: 1
+
+  interrupts:
+    maxItems: 1
+
+  power-domains:
+    maxItems: 1
+
+  clocks:
+    minItems: 8
+    maxItems: 8
+
+  clock-names:
+    items:
+      - const: infra_sys_audio_clk
+      - const: infra_sys_audio_26m
+      - const: mtkaif_26m_clk
+      - const: top_mux_audio
+      - const: top_mux_aud_intbus
+      - const: top_sys_pll3_d4
+      - const: top_sys_pll1_d4
+      - const: top_clk26m_clk
+
+required:
+  - compatible
+  - reg
+  - interrupts
+  - power-domains
+  - clocks
+  - clock-names
+
+additionalProperties: false
-- 
2.43.0
