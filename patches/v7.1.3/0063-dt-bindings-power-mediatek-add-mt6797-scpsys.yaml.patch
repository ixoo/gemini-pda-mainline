From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Julien Etienne <julien.etienne@gmail.com>
Date: Mon, 13 Jul 2026 09:15:00 -0400
Subject: [PATCH] dt-bindings: power: mediatek: add MT6797 SCPSYS binding

The MT6797 SCPSYS driver still uses the legacy, single-node binding.  Describe
the exact contract used by the upstream driver and Gemini device tree rather
than selecting the newer nested power-controller schema.

Signed-off-by: Julien Etienne <julien.etienne@gmail.com>
---
 Documentation/devicetree/bindings/power/mediatek,mt6797-scpsys.yaml | 68 ++++++++++++++++
 1 file changed, 68 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/power/mediatek,mt6797-scpsys.yaml

diff --git a/Documentation/devicetree/bindings/power/mediatek,mt6797-scpsys.yaml b/Documentation/devicetree/bindings/power/mediatek,mt6797-scpsys.yaml
new file mode 100644
--- /dev/null
+++ b/Documentation/devicetree/bindings/power/mediatek,mt6797-scpsys.yaml
@@ -0,0 +1,77 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/power/mediatek,mt6797-scpsys.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: MediaTek MT6797 SCPSYS power controller
+
+maintainers:
+  - Matthias Brugger <mbrugger@suse.com>
+  - AngeloGioacchino Del Regno <angelogioacchino.delregno@collabora.com>
+
+description: |
+  The MT6797 System Control Processor System (SCPSYS) provides the generic
+  power domains used by multimedia, video decode, audio, and GPU consumers.
+  This binding describes the legacy single-node provider consumed by the
+  mtk-scpsys driver.
+
+properties:
+  $nodename:
+    pattern: '^power-controller(@[0-9a-f]+)?$'
+
+  compatible:
+    const: mediatek,mt6797-scpsys
+
+  reg:
+    maxItems: 1
+
+  infracfg:
+    $ref: /schemas/types.yaml#/definitions/phandle
+    description: Phandle to the MT6797 infracfg syscon.
+
+  '#power-domain-cells':
+    const: 1
+
+  clocks:
+    minItems: 4
+    maxItems: 4
+
+  clock-names:
+    items:
+      - const: mfg
+      - const: mfg_52m
+      - const: mm
+      - const: vdec
+
+required:
+  - compatible
+  - reg
+  - infracfg
+  - '#power-domain-cells'
+  - clocks
+  - clock-names
+
+additionalProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/clock/mt6797-clk.h>
+    #include <dt-bindings/power/mt6797-power.h>
+
+    soc {
+        #address-cells = <2>;
+        #size-cells = <2>;
+
+        scpsys: power-controller@10006000 {
+            compatible = "mediatek,mt6797-scpsys";
+            #power-domain-cells = <1>;
+            reg = <0 0x10006000 0 0x1000>;
+            infracfg = <&infracfg>;
+            clocks = <&topckgen CLK_TOP_MUX_MFG>,
+                     <&topckgen CLK_TOP_MUX_MFG_52M>,
+                     <&topckgen CLK_TOP_MUX_MM>,
+                     <&topckgen CLK_TOP_MUX_VDEC>;
+            clock-names = "mfg", "mfg_52m", "mm", "vdec";
+        };
+    };
-- 
