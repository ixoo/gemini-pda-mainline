From fbc9ad6f0c031dd6e829af0dde1cbec0bd7cbd92 Mon Sep 17 00:00:00 2001
From: Julien Etienne <julien.etienne@gmail.com>
Date: Sun, 12 Jul 2026 14:26:32 -0400
Subject: [PATCH] arm64: dts: mediatek: add disabled MT6797 MFG clock

---
 arch/arm64/boot/dts/mediatek/mt6797.dtsi | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/arch/arm64/boot/dts/mediatek/mt6797.dtsi b/arch/arm64/boot/dts/mediatek/mt6797.dtsi
index 638ddb21a..bfbc8d084 100644
--- a/arch/arm64/boot/dts/mediatek/mt6797.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt6797.dtsi
@@ -232,6 +232,13 @@ scpsys: power-controller@10006000 {
 		infracfg = <&infrasys>;
 	};
 
+	mfgsys: syscon@13000000 {
+		compatible = "mediatek,mt6797-mfgsys", "syscon";
+		reg = <0 0x13000000 0 0x1000>;
+		#clock-cells = <1>;
+		status = "disabled";
+	};
+
 	watchdog: watchdog@10007000 {
 		compatible = "mediatek,mt6797-wdt", "mediatek,mt6589-wdt";
 		reg = <0 0x10007000 0 0x100>;
-- 
2.43.0

