 .../memory-controllers/mediatek,smi-common.yaml |  2 +
 .../memory-controllers/mediatek,smi-larb.yaml |  1 +
 .../dt-bindings/memory/mt6797-larb-port.h      | 100 +++++++++++++++++
 4 files changed, 106 insertions(+)

