From: Gemini PDA Mainline Project <noreply@example.com>
Date: Sun, 12 Jul 2026 02:06:00 -0400
Subject: [PATCH 25/25] arm64: dts: mediatek: mt6797: add M4U and SMI

Describe the MT6797 multimedia IOMMU, SMI common, all seven local arbiters,
and the two previously missing CAM and MJC clock providers.

Keep the M4U and larbs disabled at SoC level. A board may enable the
complete fabric when it has consumers ready; partial enablement would leave
component links and runtime power dependencies incomplete.

Signed-off-by: Gemini PDA Mainline Project <noreply@example.com>
---
 arch/arm64/boot/dts/mediatek/mt6797.dtsi | 111 +++++++++++++++++++++++
 1 file changed, 111 insertions(+)

diff --git a/arch/arm64/boot/dts/mediatek/mt6797.dtsi b/arch/arm64/boot/dts/mediatek/mt6797.dtsi
--- a/arch/arm64/boot/dts/mediatek/mt6797.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt6797.dtsi
@@ -8,6 +8,7 @@
 #include <dt-bindings/interrupt-controller/irq.h>
 #include <dt-bindings/interrupt-controller/arm-gic.h>
 #include <dt-bindings/pinctrl/mt6797-pinfunc.h>
+#include <dt-bindings/power/mt6797-power.h>
 #include <dt-bindings/reset/mt6797-resets.h>
 
 / {
@@ -276,6 +277,17 @@ sysirq: interrupt-controller@10200620 {
 		      <0 0x10220690 0 0x10>;
 	};
 
+	m4u: iommu@10205000 {
+		compatible = "mediatek,mt6797-m4u";
+		reg = <0 0x10205000 0 0x1000>;
+		interrupts = <GIC_SPI 156 IRQ_TYPE_LEVEL_LOW>;
+		mediatek,infracfg = <&infrasys>;
+		mediatek,larbs = <&larb0>, <&larb1>, <&larb2>, <&larb3>,
+				 <&larb4>, <&larb5>, <&larb6>;
+		#iommu-cells = <1>;
+		status = "disabled";
+	};
+
 	uart0: serial@11002000 {
 		compatible = "mediatek,mt6797-uart",
 			     "mediatek,mt6577-uart";
@@ -494,30 +506,112 @@ mmc1: mmc@11240000 {
 		status = "disabled";
 	};
 
+	mjcsys: syscon@12000000 {
+		compatible = "mediatek,mt6797-mjcsys", "syscon";
+		reg = <0 0x12000000 0 0x1000>;
+		#clock-cells = <1>;
+	};
+
+	larb4: larb@12002000 {
+		compatible = "mediatek,mt6797-smi-larb";
+		reg = <0 0x12002000 0 0x1000>;
+		mediatek,smi = <&smi_common>;
+		power-domains = <&scpsys MT6797_POWER_DOMAIN_MJC>;
+		clocks = <&mjcsys CLK_MJC_LARB4_ASIF>,
+			 <&mjcsys CLK_MJC_SMI_LARB>;
+		clock-names = "apb", "smi";
+		status = "disabled";
+	};
+
 	mmsys: syscon@14000000 {
 		compatible = "mediatek,mt6797-mmsys", "syscon";
 		reg = <0 0x14000000 0 0x1000>;
 		#clock-cells = <1>;
 	};
 
+	larb0: larb@14020000 {
+		compatible = "mediatek,mt6797-smi-larb";
+		reg = <0 0x14020000 0 0x1000>;
+		mediatek,smi = <&smi_common>;
+		power-domains = <&scpsys MT6797_POWER_DOMAIN_MM>;
+		clocks = <&mmsys CLK_MM_SMI_LARB0>,
+			 <&mmsys CLK_MM_SMI_LARB0>;
+		clock-names = "apb", "smi";
+		status = "disabled";
+	};
+
+	larb5: larb@14021000 {
+		compatible = "mediatek,mt6797-smi-larb";
+		reg = <0 0x14021000 0 0x1000>;
+		mediatek,smi = <&smi_common>;
+		power-domains = <&scpsys MT6797_POWER_DOMAIN_MM>;
+		clocks = <&mmsys CLK_MM_SMI_LARB5>,
+			 <&mmsys CLK_MM_SMI_LARB5>;
+		clock-names = "apb", "smi";
+		status = "disabled";
+	};
+
+	smi_common: smi@14022000 {
+		compatible = "mediatek,mt6797-smi-common";
+		reg = <0 0x14022000 0 0x1000>;
+		power-domains = <&scpsys MT6797_POWER_DOMAIN_MM>;
+		clocks = <&mmsys CLK_MM_SMI_COMMON>,
+			 <&mmsys CLK_MM_SMI_COMMON>;
+		clock-names = "apb", "smi";
+		status = "disabled";
+	};
+
 	imgsys: syscon@15000000  {
 		compatible = "mediatek,mt6797-imgsys", "syscon";
 		reg = <0 0x15000000 0 0x1000>;
 		#clock-cells = <1>;
 	};
 
+	larb6: larb@15001000 {
+		compatible = "mediatek,mt6797-smi-larb";
+		reg = <0 0x15001000 0 0x1000>;
+		mediatek,smi = <&smi_common>;
+		power-domains = <&scpsys MT6797_POWER_DOMAIN_ISP>;
+		clocks = <&imgsys CLK_IMG_LARB6>,
+			 <&imgsys CLK_IMG_LARB6>;
+		clock-names = "apb", "smi";
+		status = "disabled";
+	};
+
 	vdecsys: syscon@16000000 {
 		compatible = "mediatek,mt6797-vdecsys", "syscon";
 		reg = <0 0x16000000 0 0x10000>;
 		#clock-cells = <1>;
 	};
 
+	larb1: larb@16010000 {
+		compatible = "mediatek,mt6797-smi-larb";
+		reg = <0 0x16010000 0 0x10000>;
+		mediatek,smi = <&smi_common>;
+		power-domains = <&scpsys MT6797_POWER_DOMAIN_VDEC>;
+		clocks = <&vdecsys CLK_VDEC_CKEN>,
+			 <&vdecsys CLK_VDEC_LARB1_CKEN>;
+		clock-names = "apb", "smi";
+		status = "disabled";
+	};
+
 	vencsys: syscon@17000000 {
 		compatible = "mediatek,mt6797-vencsys", "syscon";
 		reg = <0 0x17000000 0 0x1000>;
 		#clock-cells = <1>;
 	};
 
+	larb3: larb@17001000 {
+		compatible = "mediatek,mt6797-smi-larb";
+		reg = <0 0x17001000 0 0x1000>;
+		mediatek,smi = <&smi_common>;
+		power-domains = <&scpsys MT6797_POWER_DOMAIN_VENC>;
+		clocks = <&vencsys CLK_VENC_1>,
+			 <&vencsys CLK_VENC_1>;
+		clock-names = "apb", "smi";
+		status = "disabled";
+	};
+
 	gic: interrupt-controller@19000000 {
 		compatible = "arm,gic-v3";
 		#interrupt-cells = <3>;
@@ -528,3 +622,20 @@ gic: interrupt-controller@19000000 {
 		      <0 0x10240000 0 0x2000>;     /* GICC */
 	};
+
+	camsys: syscon@1a000000 {
+		compatible = "mediatek,mt6797-camsys", "syscon";
+		reg = <0 0x1a000000 0 0x1000>;
+		#clock-cells = <1>;
+	};
+
+	larb2: larb@1a001000 {
+		compatible = "mediatek,mt6797-smi-larb";
+		reg = <0 0x1a001000 0 0x1000>;
+		mediatek,smi = <&smi_common>;
+		power-domains = <&scpsys MT6797_POWER_DOMAIN_ISP>;
+		clocks = <&camsys CLK_CAM_LARB2>,
+			 <&camsys CLK_CAM_LARB2>;
+		clock-names = "apb", "smi";
+		status = "disabled";
+	};
 };
-- 
2.47.2
