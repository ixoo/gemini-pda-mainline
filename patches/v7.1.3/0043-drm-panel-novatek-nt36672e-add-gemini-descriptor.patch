+$id: http://devicetree.org/schemas/display/panel/planet,gemini-pda-nt36672.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Planet Gemini PDA NT36672 DSI Panel
+
+maintainers:
+  - Julien Etienne <julien.etienne@gmail.com>
+
+allOf:
+  - $ref: panel-common.yaml#
+
+properties:
+  compatible:
+    const: planet,gemini-pda-nt36672
+
+  reg:
+    maxItems: 1
+    description: DSI virtual channel
+
+  outp-supply: true
+  outn-supply: true
+  reset-gpios: true
