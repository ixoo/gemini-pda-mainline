#!/usr/bin/env bash

set -euo pipefail

die() {
  echo "error: $*" >&2
  exit 1
}

usage() {
  cat <<'EOF'
Usage: ./scripts/validate-kernel-artifact [ARTIFACT_DIR]

Validate a packaged kernel artifact in the development VM. With no argument,
the newest package below ~/artifacts/gemini-pda is selected.
EOF
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

[[ "$(uname -s)" == Linux ]] || die "run this command inside the development VM"
[[ "$(uname -m)" == aarch64 ]] || die "expected an aarch64 development VM"

for command in awk basename cmp find gzip head jq od sha256sum sort tail tr uniq wc; do
  require_command "${command}"
done

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  "")
    artifact_root="${GEMINI_ARTIFACT_ROOT:-${HOME}/artifacts/gemini-pda}"
    artifact_record="$(find "${artifact_root}" -mindepth 1 -maxdepth 1 \
      -type d -name 'linux-*-gemini-*' -printf '%T@ %p\n' \
      | sort -n | tail -n 1)"
    artifact_dir="${artifact_record#* }"
    [[ -n "${artifact_dir}" ]] || die "no packaged kernel artifacts found below ${artifact_root}"
    ;;
  *)
    [[ "$#" -eq 1 ]] || die "accepts at most one artifact directory"
    artifact_dir="$1"
    ;;
esac

[[ -d "${artifact_dir}" ]] || die "artifact directory does not exist: ${artifact_dir}"
[[ -f "${artifact_dir}/SHA256SUMS" && ! -L "${artifact_dir}/SHA256SUMS" ]] || \
  die "missing or non-regular SHA256SUMS in ${artifact_dir}"
[[ -f "${artifact_dir}/provenance/build.json" ]] || \
  die "missing provenance/build.json in ${artifact_dir}"
unexpected_entry="$(find "${artifact_dir}" -mindepth 1 \
  ! -type d ! -type f -print -quit)"
[[ -z "${unexpected_entry}" ]] || \
  die "artifact tree contains a non-regular entry: ${unexpected_entry}"

for file in Image Image.gz kernel.config System.map provenance/build.json \
  provenance/kernel-manifest.json provenance/series; do
  [[ -s "${artifact_dir}/${file}" ]] || die "missing or empty artifact file: ${file}"
done

gzip -t "${artifact_dir}/Image.gz" || die "Image.gz is not a valid gzip stream"
image_gzip_decompressed_size="$(gzip -cd "${artifact_dir}/Image.gz" | wc -c)"
(( image_gzip_decompressed_size <= 0x03200000 )) || \
  die "Image.gz decompresses beyond the MT6797 LK 50 MiB buffer: ${image_gzip_decompressed_size}"
gzip -cd "${artifact_dir}/Image.gz" | cmp -s - "${artifact_dir}/Image" || \
  die "Image.gz does not decompress byte-for-byte to the packaged Image"

image_size="$(wc -c < "${artifact_dir}/Image")"
[[ "${image_size}" -eq "${image_gzip_decompressed_size}" ]] || \
  die "packaged Image size does not match the gzip stream"
image_magic="$(od -An -tx1 -N4 -j56 "${artifact_dir}/Image" | tr -d ' \n')"
[[ "${image_magic}" == 41524d64 ]] || \
  die "packaged Image is missing the ARM64 Image magic at offset 56"
image_text_offset="$(od -An -tu8 -N8 -j8 "${artifact_dir}/Image" | tr -d ' ')"
image_effective_size="$(od -An -tu8 -N8 -j16 "${artifact_dir}/Image" | tr -d ' ')"
[[ "${image_text_offset}" =~ ^[0-9]+$ ]] || die "invalid ARM64 Image text offset"
[[ "${image_effective_size}" =~ ^[0-9]+$ && "${image_effective_size}" -gt 0 ]] || \
  die "invalid ARM64 Image effective size"
(( image_effective_size <= 0x03200000 )) || \
  die "ARM64 Image effective size exceeds the MT6797 LK 50 MiB region: ${image_effective_size}"

dtb_count="$(find "${artifact_dir}/dtbs/mediatek" -type f -name '*.dtb' | wc -l)"
[[ "${dtb_count}" -gt 0 ]] || die "no MediaTek DTBs found in ${artifact_dir}/dtbs/mediatek"

invalid_manifest_line="$(awk '
  length($1) != 64 || $1 ~ /[^0-9a-f]/ || NF != 2 ||
  $2 !~ /^\.\// || $2 == "./SHA256SUMS" ||
  $2 ~ /(^|\/)\.\.($|\/)/ || $2 ~ /\/\// {
    print NR ":" $0
    exit
  }
' "${artifact_dir}/SHA256SUMS")"
[[ -z "${invalid_manifest_line}" ]] || \
  die "unsafe or malformed SHA256SUMS line: ${invalid_manifest_line}"
manifest_paths="$(awk '{ print $2 }' "${artifact_dir}/SHA256SUMS" | sort)"
duplicate_manifest_path="$(printf '%s\n' "${manifest_paths}" | uniq -d | head -n 1)"
[[ -z "${duplicate_manifest_path}" ]] || \
  die "duplicate SHA256SUMS path: ${duplicate_manifest_path}"
actual_paths="$(cd "${artifact_dir}" && \
  find . -type f ! -path ./SHA256SUMS -print | sort)"
[[ "${manifest_paths}" == "${actual_paths}" ]] || \
  die "SHA256SUMS is not an exact inventory of the artifact's regular files"

(
  cd "${artifact_dir}"
  sha256sum --check --strict SHA256SUMS
)

jq -e '
  .schema == 1 and
  (.kernel_release | length > 0) and
  ((.build_profile == null) or (.build_profile | test("^[a-z0-9][a-z0-9_-]*$"))) and
  ((.base_config == null) or (.base_config | length > 0)) and
  ((.config_fragments == null) or (.config_fragments | type == "array")) and
  ((.config_inputs_sha256 == null) or (.config_inputs_sha256 | test("^[0-9a-f]{64}$"))) and
  (.source_sha256 | test("^[0-9a-f]{64}$")) and
  (.patchset_sha256 | test("^[0-9a-f]{64}$")) and
  (.config_sha256 | test("^[0-9a-f]{64}$")) and
  ((.modules_built == null) or (.modules_built | type == "boolean")) and
  (.compiler | length > 0) and
  (.linker | length > 0)
' "${artifact_dir}/provenance/build.json" >/dev/null || \
  die "invalid provenance/build.json"
[[ "$(jq -er '.config_sha256' "${artifact_dir}/provenance/build.json")" == \
  "$(sha256sum "${artifact_dir}/kernel.config" | awk '{print $1}')" ]] || \
  die "provenance config_sha256 does not match kernel.config"

printf 'validation=kernel-artifact\n'
printf 'artifact=%s\n' "$(basename "${artifact_dir}")"
printf 'kernel_release=%s\n' "$(jq -er '.kernel_release' "${artifact_dir}/provenance/build.json")"
printf 'build_profile=%s\n' "$(jq -er '.build_profile // "legacy"' "${artifact_dir}/provenance/build.json")"
printf 'generated_utc=%s\n' "$(jq -er '.generated_utc' "${artifact_dir}/provenance/build.json")"
printf 'source_sha256=%s\n' "$(jq -er '.source_sha256' "${artifact_dir}/provenance/build.json")"
printf 'patchset_sha256=%s\n' "$(jq -er '.patchset_sha256' "${artifact_dir}/provenance/build.json")"
printf 'config_sha256=%s\n' "$(jq -er '.config_sha256' "${artifact_dir}/provenance/build.json")"
printf 'modules_built=%s\n' "$(jq -er '.modules_built // false' "${artifact_dir}/provenance/build.json")"
printf 'image_gzip_sha256=%s\n' "$(sha256sum "${artifact_dir}/Image.gz" | awk '{print $1}')"
printf 'image_gzip_decompressed_size=%s\n' "${image_gzip_decompressed_size}"
printf 'image_text_offset=%s\n' "${image_text_offset}"
printf 'image_effective_size=%s\n' "${image_effective_size}"
printf 'dtb_count=%s\n' "${dtb_count}"
printf 'sha256sums=passed\n'
printf 'hardware_write=none\n'
