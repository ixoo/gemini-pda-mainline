#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
readonly SCRIPT_DIR
REPO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd -P)"
readonly REPO_DIR
readonly CONFIG_FILE="${REPO_DIR}/vm/lima.yaml"
readonly INSTANCE="${DEV_VM_NAME:-gemini-pda-dev}"
readonly CPUS="${DEV_VM_CPUS:-8}"
readonly MEMORY_GIB="${DEV_VM_MEMORY_GIB:-8}"
readonly DISK_GIB="${DEV_VM_DISK_GIB:-100}"

usage() {
  cat <<'EOF'
Usage: ./scripts/dev-vm COMMAND [ARGUMENTS]

Commands:
  setup                 Install Lima if needed, create the VM, and start it
  install-host          Install Lima with Homebrew
  start                 Start an existing VM
  stop                  Stop the VM
  shell                 Open an interactive guest shell
  re-shell              Open a shell in the extracted vendor payload
  run COMMAND...        Run a command in the guest
  provision             Re-run system and user provisioning
  doctor                Validate the host and guest setup
  status                Show VM status
  kernel COMMAND...     Run the pinned-kernel workflow (prepare/configure/build)
  build-kernel          Prepare, configure, build, and package the kernel
  build-handoff-kernel  Build the built-in-only LK handoff kernel profile
  build-usbdiag-kernel  Build the minimal left-port USB diagnostic profile
  validate-kernel [DIR] Verify a packaged kernel artifact and its provenance
  export-artifacts [DIR]
                        Copy ~/artifacts to a new host directory
  export-artifact PATH [DIR]
                        Copy one path below ~/artifacts to the host
  remove --force        Permanently delete the VM and its guest filesystem

Creation overrides:
  DEV_VM_NAME           Instance name (default: gemini-pda-dev)
  DEV_VM_CPUS           Virtual CPUs (default: 8)
  DEV_VM_MEMORY_GIB     Memory in GiB (default: 8)
  DEV_VM_DISK_GIB       Disk in GiB (default: 100)

Build overrides:
  KERNEL_PROFILE=NAME   Select a manifest kernel profile (default: full)
  BUILD_MODULES=1       Also install CONFIG_*=m outputs into modules/
  KERNEL_JOBS=N          Parallel kernel build jobs (default: guest policy)
EOF
}

die() {
  echo "error: $*" >&2
  exit 1
}

require_supported_host() {
  [[ "$(uname -s)" == Darwin ]] || die "the managed VM currently supports macOS only"
  [[ "$(uname -m)" == arm64 ]] || die "the managed VM currently supports Apple Silicon only"
}

require_lima() {
  command -v limactl >/dev/null 2>&1 || die "Lima is not installed; run ./scripts/dev-vm install-host"
}

instance_exists() {
  limactl list --format '{{.Name}}' 2>/dev/null | grep -Fxq "${INSTANCE}"
}

install_host() {
  require_supported_host
  if command -v limactl >/dev/null 2>&1; then
    echo "Lima is already installed: $(limactl --version)"
    return
  fi
  command -v brew >/dev/null 2>&1 || die "Homebrew is required to install Lima"
  brew install lima
}

create_vm() {
  if instance_exists; then
    echo "VM ${INSTANCE} already exists"
    return
  fi

  limactl create \
    --tty=false \
    --name="${INSTANCE}" \
    --cpus="${CPUS}" \
    --memory="${MEMORY_GIB}" \
    --disk="${DISK_GIB}" \
    --param="repoDir=${REPO_DIR}" \
    "${CONFIG_FILE}"
}

start_vm() {
  instance_exists || die "VM ${INSTANCE} does not exist; run ./scripts/dev-vm setup"
  limactl start "${INSTANCE}"
}

run_provisioning() {
  start_vm
  limactl shell --workdir=/tmp "${INSTANCE}" -- \
    sudo bash /mnt/gemini-pda-mainline/vm/provision.sh system
  limactl shell --workdir=/tmp "${INSTANCE}" -- \
    bash /mnt/gemini-pda-mainline/vm/provision.sh user
}

doctor() {
  require_supported_host
  require_lima
  instance_exists || die "VM ${INSTANCE} does not exist; run ./scripts/dev-vm setup"

  echo "Host:  $(uname -s) $(uname -m)"
  echo "Lima:  $(limactl --version)"
  limactl list "${INSTANCE}"
  # The quoted variables below are expanded by the guest shell.
  # shellcheck disable=SC2016
  limactl shell --workdir=/tmp "${INSTANCE}" -- bash -lc '
    set -euo pipefail
    test "$(uname -m)" = aarch64
    test -r /mnt/gemini-pda-mainline/README.md
    test ! -w /mnt/gemini-pda-mainline
    command -v make >/dev/null
    command -v busybox >/dev/null
    command -v dtc >/dev/null
    command -v pahole >/dev/null
    command -v dt-doc-validate >/dev/null
    command -v yamllint >/dev/null
    command -v gdb-multiarch >/dev/null
    command -v r2 >/dev/null
    command -v rabin2 >/dev/null
    command -v eu-readelf >/dev/null
    command -v qemu-arm-static >/dev/null
    command -v qemu-aarch64-static >/dev/null
    command -v apktool >/dev/null
    command -v binwalk >/dev/null
    command -v yara >/dev/null
    command -v ghidra-analyze >/dev/null
    command -v vmlinux-to-elf >/dev/null
    python3 -c "import git, ply"
    test -x "$HOME/.local/opt/ghidra_12.1.2_PUBLIC/Ghidra/Features/Decompiler/build/os/linux_arm_64/decompile"
    printf "Guest: %s %s\n" "$(. /etc/os-release; printf %s "$PRETTY_NAME")" "$(uname -m)"
    printf "Tools: make=%s dtc=%s dtschema=%s\n" \
      "$(make --version | head -n 1)" \
      "$(dtc --version)" \
      "$("$HOME/.local/share/venvs/dtschema/bin/python" -m pip show dtschema | awk "/^Version:/ { print \$2 }")"
    printf "RE:    gdb=%s radare2=%s vmlinux-to-elf=%s Ghidra=%s\n" \
      "$(gdb-multiarch --version | head -n 1)" \
      "$(r2 -v | head -n 1)" \
      "$(vmlinux-to-elf --help | head -n 1)" \
      "$(awk -F= "/^application.version=/ { print \$2 }" "$HOME/.local/opt/ghidra_12.1.2_PUBLIC/Ghidra/application.properties")"
    if test -r /mnt/gemini-pda-mainline/artifacts/device-userspace/latest/FILES.sha256; then
      test -r "$HOME/reverse-engineering/gemini-vendor/FILES.sha256"
      printf "Payload: %s\n" "$HOME/reverse-engineering/gemini-vendor"
    else
      printf "Payload: not extracted on host; run scripts/extract-device-userspace\n"
    fi
  '
}

export_artifacts() {
  local destination="${1:-${REPO_DIR}/artifacts/$(date -u +%Y%m%dT%H%M%SZ)}"
  start_vm
  mkdir -p "${destination}"
  # HOME is expanded by the guest shell.
  # shellcheck disable=SC2016
  limactl shell --workdir=/tmp "${INSTANCE}" -- bash -lc 'tar -C "$HOME/artifacts" -cf - .' \
    | tar -C "${destination}" -xf -
  echo "Artifacts exported to ${destination}"
}

export_artifact() {
  local relative="$1"
  local destination="${2:-${REPO_DIR}/artifacts/vm-export}"
  local host_target

  case "${relative}" in
    ''|/*|.|..|../*|*/../*|*/..)
      die "export-artifact PATH must be a child path below guest ~/artifacts"
      ;;
  esac
  [[ "${relative}" != *$'\n'* ]] || die "export-artifact PATH must be one line"

  host_target="${destination}/${relative}"
  [[ ! -e "${host_target}" ]] || die "refusing to overwrite ${host_target}"
  start_vm
  mkdir -p "${destination}"
  # The quoted variables below are expanded by the guest shell.
  # shellcheck disable=SC2016
  limactl shell --workdir=/tmp "${INSTANCE}" -- \
    env GEMINI_ARTIFACT_RELATIVE="${relative}" bash -lc '
      set -euo pipefail
      cd "$HOME/artifacts"
      test -e "$GEMINI_ARTIFACT_RELATIVE"
      tar -cf - -- "$GEMINI_ARTIFACT_RELATIVE"
    ' | tar -C "${destination}" -xf -
  echo "Artifact exported to ${host_target}"
}

readonly COMMAND="${1:-}"
[[ -n "${COMMAND}" ]] || {
  usage
  exit 2
}
shift

case "${COMMAND}" in
  setup)
    require_supported_host
    install_host
    require_lima
    create_vm
    start_vm
    doctor
    ;;
  install-host)
    install_host
    ;;
  start)
    require_lima
    start_vm
    ;;
  stop)
    require_lima
    instance_exists || die "VM ${INSTANCE} does not exist"
    limactl stop "${INSTANCE}"
    ;;
  shell)
    require_lima
    start_vm
    # HOME and SHELL are expanded by the guest shell.
    # shellcheck disable=SC2016
    exec limactl shell --workdir=/tmp "${INSTANCE}" -- \
      bash -lc 'cd "$HOME" && exec "${SHELL:-/bin/bash}" -l'
    ;;
  re-shell)
    require_lima
    start_vm
    # HOME and SHELL are expanded by the guest shell.
    # shellcheck disable=SC2016
    exec limactl shell --workdir=/tmp "${INSTANCE}" -- \
      bash -lc 'test -d "$HOME/reverse-engineering/gemini-vendor" || { echo "vendor payload unavailable; run scripts/extract-device-userspace on the host" >&2; exit 1; }; cd "$HOME/reverse-engineering/gemini-vendor" && exec "${SHELL:-/bin/bash}" -l'
    ;;
  run)
    require_lima
    [[ "$#" -gt 0 ]] || die "run requires a command"
    start_vm
    exec limactl shell --workdir=/mnt/gemini-pda-mainline "${INSTANCE}" -- "$@"
    ;;
  provision)
    require_lima
    run_provisioning
    ;;
  doctor)
    doctor
    ;;
  status)
    require_lima
    limactl list "${INSTANCE}"
    ;;
  kernel)
    require_lima
    [[ "$#" -gt 0 ]] || die "kernel requires a command; try: ./scripts/dev-vm kernel status"
    start_vm
    kernel_env=()
    for variable in KERNEL_PROFILE BUILD_MODULES KERNEL_JOBS; do
      if [[ -n "${!variable:-}" ]]; then
        kernel_env+=("${variable}=${!variable}")
      fi
    done
    if ((${#kernel_env[@]} > 0)); then
      exec limactl shell --workdir=/mnt/gemini-pda-mainline "${INSTANCE}" -- \
        env "${kernel_env[@]}" ./scripts/kernel "$@"
    else
      exec limactl shell --workdir=/mnt/gemini-pda-mainline "${INSTANCE}" -- \
        ./scripts/kernel "$@"
    fi
    ;;
  build-kernel)
    require_lima
    [[ "$#" -eq 0 ]] || die "build-kernel does not accept arguments"
    start_vm
    # Forward only the documented build controls; the repository mount remains
    # read-only and all generated sources/artifacts stay in the guest.
    build_env=()
    for variable in KERNEL_PROFILE BUILD_MODULES KERNEL_JOBS; do
      if [[ -n "${!variable:-}" ]]; then
        build_env+=("${variable}=${!variable}")
      fi
    done
    if ((${#build_env[@]} > 0)); then
      exec limactl shell --workdir=/mnt/gemini-pda-mainline "${INSTANCE}" -- \
        env "${build_env[@]}" ./scripts/kernel build
    else
      exec limactl shell --workdir=/mnt/gemini-pda-mainline "${INSTANCE}" -- \
        ./scripts/kernel build
    fi
    ;;
  build-handoff-kernel)
    require_lima
    [[ "$#" -eq 0 ]] || die "build-handoff-kernel does not accept arguments"
    start_vm
    build_env=("KERNEL_PROFILE=handoff")
    for variable in BUILD_MODULES KERNEL_JOBS; do
      if [[ -n "${!variable:-}" ]]; then
        build_env+=("${variable}=${!variable}")
      fi
    done
    exec limactl shell --workdir=/mnt/gemini-pda-mainline "${INSTANCE}" -- \
      env "${build_env[@]}" ./scripts/kernel build
    ;;
  build-usbdiag-kernel)
    require_lima
    [[ "$#" -eq 0 ]] || die "build-usbdiag-kernel does not accept arguments"
    start_vm
    build_env=("KERNEL_PROFILE=usbdiag")
    for variable in BUILD_MODULES KERNEL_JOBS; do
      if [[ -n "${!variable:-}" ]]; then
        build_env+=("${variable}=${!variable}")
      fi
    done
    exec limactl shell --workdir=/mnt/gemini-pda-mainline "${INSTANCE}" -- \
      env "${build_env[@]}" ./scripts/kernel build
    ;;
  validate-kernel)
    require_lima
    [[ "$#" -le 1 ]] || die "validate-kernel accepts at most one artifact directory"
    start_vm
    exec limactl shell --workdir=/mnt/gemini-pda-mainline "${INSTANCE}" -- \
      ./scripts/validate-kernel-artifact "$@"
    ;;
  export-artifacts)
    require_lima
    [[ "$#" -le 1 ]] || die "export-artifacts accepts at most one destination"
    export_artifacts "${1:-}"
    ;;
  export-artifact)
    require_lima
    [[ "$#" -ge 1 && "$#" -le 2 ]] || die "export-artifact requires PATH and accepts an optional destination"
    export_artifact "$1" "${2:-}"
    ;;
  remove)
    require_lima
    [[ "${1:-}" == --force ]] || die "remove is destructive; repeat with: ./scripts/dev-vm remove --force"
    instance_exists || die "VM ${INSTANCE} does not exist"
    limactl stop "${INSTANCE}" 2>/dev/null || true
    limactl delete --tty=false "${INSTANCE}"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
